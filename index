<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌴 Bảng hoa Queens - Đồng bộ song song 2 Sheets 🐚</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght=400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* ----- HỆ THỐNG BIẾN ----- */
        :root {
            --sea-main: #0096c7; 
            --sea-dark: #0077b6;
            --text-dark: #1d3557;
            --text-gray: #457b9d;
            --boy-bg: rgba(235, 252, 255, 0.85); 
            --boy-border: #48cae4;
            --glass-bg: rgba(255, 255, 255, 0.75);
            --glass-border: rgba(255, 255, 255, 0.9);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Be Vietnam Pro', sans-serif; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.5); border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: #48cae4; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--sea-main); }
        
        body { 
            background: linear-gradient(180deg, #caf0f8 0%, #90e0ef 30%, #48cae4 70%, #f2cc8f 100%);
            background-attachment: fixed;
            padding: 20px 10px; 
            display: flex; 
            justify-content: center; 
            min-height: 100vh; 
        }

        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-15px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeInSoft { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes floating { 0%, 100% { transform: translateY(0px) rotate(0deg); } 50% { transform: translateY(-12px) rotate(8deg); } }

        /* 🔥 HIỆU ỨNG HÀO QUANG (GLOW) CHO HOA HIẾM 🔥 */
        @keyframes glowRed {
            0% { box-shadow: 0 0 5px rgba(230, 57, 70, 0.4), inset 0 0 5px rgba(230, 57, 70, 0.2); }
            50% { box-shadow: 0 0 15px rgba(230, 57, 70, 0.9), inset 0 0 10px rgba(230, 57, 70, 0.4); }
            100% { box-shadow: 0 0 5px rgba(230, 57, 70, 0.4), inset 0 0 5px rgba(230, 57, 70, 0.2); }
        }
        @keyframes glowOrange {
            0% { box-shadow: 0 0 5px rgba(255, 183, 77, 0.4), inset 0 0 5px rgba(255, 183, 77, 0.2); }
            50% { box-shadow: 0 0 15px rgba(255, 183, 77, 0.9), inset 0 0 10px rgba(255, 183, 77, 0.4); }
            100% { box-shadow: 0 0 5px rgba(255, 183, 77, 0.4), inset 0 0 5px rgba(255, 183, 77, 0.2); }
        }

        /* ----- CONTAINER CHÍNH ----- */
        .garden-container { 
            width: 100%; max-width: 520px; 
            background: var(--glass-bg); 
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            padding: 25px 15px; border-radius: 30px; 
            box-shadow: 0 25px 50px rgba(0, 150, 199, 0.15); 
            border: 2px solid var(--glass-border); 
            position: relative; 
            animation: fadeInDown 0.6s ease-out;
        }
        
        .decor-float { position: absolute; top: -20px; font-size: 38px; animation: floating 3s ease-in-out infinite; cursor: pointer; text-shadow: 0 5px 15px rgba(0, 180, 216, 0.3); }
        .decor-float.left { left: 10px; }
        .decor-float.right { right: 10px; animation-delay: 1.5s; top: -15px; }

        .main-title { text-align: center; color: var(--sea-dark); margin-bottom: 20px; font-size: 22px; text-shadow: 2px 2px 4px rgba(255,255,255,0.8); }
        .loading-screen { text-align: center; padding: 40px; color: var(--sea-dark); font-weight: 700; font-size: 16px; }

        /* ----- LAYOUT BỐ CỤC ----- */
        .main-layout { display: flex; flex-direction: column; gap: 20px; }
        .left-col { display: flex; flex-direction: column; gap: 20px; }
        .right-col { display: flex; flex-direction: column; }
        .button-group { display: flex; flex-direction: column; gap: 12px; }

        /* ----- TÌM KIẾM & NÚT BẤM ----- */
        .search-box { background: rgba(255, 255, 255, 0.95); border: 2px dashed #48cae4; padding: 16px; border-radius: 24px; box-shadow: inset 0 4px 10px rgba(0, 180, 216, 0.05); }
        .search-box-title { font-size: 13px; font-weight: 700; margin-bottom: 10px; text-transform: uppercase; color: var(--sea-dark); display: flex; align-items: center; gap: 6px; }
        .search-input { width: 100%; padding: 12px 16px; font-size: 14px; border-radius: 16px; border: 2px solid #caf0f8; outline: none; background: #fff; color: var(--text-dark); transition: all 0.3s; }
        .search-input:focus { border-color: var(--sea-main); box-shadow: 0 0 15px rgba(0, 180, 216, 0.3); }

        .btn-main { width: 100%; padding: 14px 18px; font-size: 14px; font-weight: 700; border: none; border-radius: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.08); }
        .btn-main:hover { transform: translateY(-3px); filter: brightness(1.08); box-shadow: 0 8px 20px rgba(0,0,0,0.12); }
        .btn-main.active-btn { transform: scale(0.98); box-shadow: inset 0 4px 10px rgba(0,0,0,0.2); outline: 3px solid rgba(255,255,255,0.8); }
        
        .btn-help { color: #855b00; background: linear-gradient(135deg, #ffe066, #ffb703); }
        .btn-rank { color: #fff; background: linear-gradient(135deg, #48cae4, #0096c7); }
        .btn-xu { color: #fff; background: linear-gradient(135deg, #2a9d8f, #264653); }

        /* ----- HỘP NỘI DUNG ----- */
        .info-box { display: none; padding: 20px; background: rgba(255, 255, 255, 0.95); border: 2px dashed #48cae4; border-radius: 24px; }
        .info-box.active { display: block; animation: fadeInSoft 0.4s ease-out forwards; }
        
        .help-content { color: var(--text-gray); font-size: 13.5px; line-height: 1.8; }
        .help-content p { margin-bottom: 6px; }
        .help-content .help-title { margin-bottom: 12px; font-weight: 700; color: var(--sea-main); font-size: 15px;}

        /* ----- BẢNG XẾP HẠNG ----- */
        .total-badge { font-size: 12px; font-weight: 700; color: #fff; margin-bottom: 14px; background: var(--sea-main); padding: 6px 14px; border-radius: 15px; display: inline-block; text-transform: uppercase; }
        .rank-list-container { display: flex; flex-direction: column; gap: 12px; }
        .cute-rank-item { border: 1.5px solid rgba(255,255,255,0.9); border-radius: 20px; overflow: hidden; background: rgba(255,255,255,0.95); transition: all 0.3s ease; }
        .gentleman-card-style.cute-rank-item { border-color: var(--boy-border); background: var(--boy-bg); }

        .click-header-line { display: flex; justify-content: space-between; align-items: center; padding: 14px 16px; cursor: pointer; user-select: none; transition: background 0.3s; }
        .click-header-line:hover { background: #fff; }
        .active-folder .click-header-line { background: #e0fbfc; }
        .active-folder.gentleman-card-style .click-header-line { background: #caf0f8; }

        .header-left { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--text-dark); font-weight: 700; }
        .rank-number { font-weight: 800; width: 24px; text-align: center; }
        .count-badge { font-weight: 700; padding: 4px 10px; border-radius: 15px; font-size: 11px; color: #fff; background: var(--sea-main); }

        .rank-content-box { display: none; padding: 16px; background: rgba(255,255,255,0.98); border-top: 1px solid #e0fbfc; }
        .active-folder .rank-content-box { display: block; animation: fadeInSoft 0.3s ease-out; }

        .summary-rarity-line { font-size: 12px; padding: 10px; margin-bottom: 12px; border-radius: 10px; background: #f0fafd; border-left: 4px solid var(--sea-main); color: var(--text-dark); font-weight: 500; }
        .flower-chip-container { display: flex; flex-wrap: wrap; gap: 5px; }
        .flower-chip-item, .xu-missing-badge { display: inline-block; padding: 6px 10px; border-radius: 12px; font-size: 11px; transition: transform 0.2s; }
        .flower-chip-item:hover, .xu-missing-badge:hover { transform: translateY(-2px); }
        
        .xu-missing-badge { background: #fff; border: 1.5px solid #e76f51; color: #e76f51; font-weight: 600; }
        .all-cleared-msg { text-align: center; padding: 16px; color: var(--sea-main); font-weight: 700; font-size: 14px; border: 2px dashed #90e0ef; border-radius: 16px; background: rgba(255,255,255,0.85); }

        /* ----- MÀU SẮC HOA VÀ GLOW (Phần được thêm vào) ----- */
        .tier-blue { background: linear-gradient(135deg, #e0f2fe, #bae6fd); border: 1px solid #7dd3fc; color: #0284c7; }
        .tier-purple { background: linear-gradient(135deg, #f3e5f5, #e1bee7); border: 1px solid #ba68c8; color: #6a1b9a; }
        .tier-orange { background: linear-gradient(135deg, #fff3e0, #ffe0b2); border: 1px solid #ffb74d; color: #e65100; font-weight: 600; animation: glowOrange 2s infinite alternate; }
        .tier-red { background: linear-gradient(135deg, #fff0f2, #ffccd5); border: 2px solid #e63946; color: #d90429; font-weight: 700; animation: glowRed 2s infinite alternate; }

        /* Text màu cho chữ phẩm chất trong ô tìm kiếm */
        .text-tier-red { color: #d90429; font-weight: 700; }
        .text-tier-orange { color: #e65100; font-weight: 700; }
        .text-tier-purple { color: #6a1b9a; font-weight: 700; }
        .text-tier-blue { color: #0284c7; font-weight: 700; }

        /* ----- TÌM KIẾM HOA ----- */
        .search-title { font-size: 13px; font-weight: 700; color: var(--sea-dark); margin-bottom: 15px; text-transform: uppercase; }
        .single-flower-block { padding: 16px; border-radius: 20px; font-size: 13px; line-height: 1.6; margin-bottom: 12px; }
        
        .flower-found { border: 2px solid #48cae4; background: #fff; color: var(--sea-dark); }
        .flower-empty { border: 2px dashed #90e0ef; background: rgba(255,255,255,0.8); color: var(--sea-main); }
        .flower-not-found { border: 2px dashed #e76f51; background: rgba(255,255,255,0.8); color: #e76f51; text-align: center; font-weight: 600;}

        /* Áp dụng hào quang cho viền ô tìm kiếm nếu là hoa Đỏ / Cam */
        .flower-found.box-tier-red { border-color: #e63946; animation: glowRed 2s infinite alternate; }
        .flower-found.box-tier-orange { border-color: #ffb74d; animation: glowOrange 2s infinite alternate; }
        .flower-empty.box-tier-red { border-color: #e63946; animation: glowRed 2s infinite alternate; }
        .flower-empty.box-tier-orange { border-color: #ffb74d; animation: glowOrange 2s infinite alternate; }


        /* ----- TỐI ƯU PC (2 CỘT CHUYÊN NGHIỆP) ----- */
        @media (min-width: 1024px) {
            body { padding: 50px 20px; }
            .garden-container { max-width: 900px; padding: 40px; border-radius: 40px; }
            .main-title { font-size: 26px; margin-bottom: 30px; }
            .main-layout { flex-direction: row; align-items: flex-start; gap: 30px; }
            .left-col { flex: 0 0 320px; position: sticky; top: 20px; }
            .right-col { flex: 1; min-width: 0; }
            .search-box { padding: 20px; margin-bottom: 0; }
            .button-group { gap: 15px; }
            .info-box { padding: 25px; min-height: 400px; } 
        }
    </style>
</head>
<body>

<div class="garden-container">
    <span class="decor-float left">🐠</span>
    <span class="decor-float right">⛵</span>

    <h2 class="main-title">🌴 Bảng hoa Queens - Hè là phải đi biển 🐚</h2>
    
    <div id="loadingArea" class="loading-screen">⚓ Đang tải dữ liệu từ bãi biển...</div>

    <div id="mainContentArea" class="main-layout" style="display: none;">
        <div class="left-col">
            <div class="search-box">
                <div class="search-box-title">🔍 Tìm hoa ở bãi biển:</div>
                <input type="text" id="flowerSearch" class="search-input" placeholder="Nhập tên loài hoa...">
            </div>
            
            <div class="button-group">
                <button id="btnHelp" class="btn-main btn-help active-btn" onclick="toggleTab('helpBox', this)">🗺️ Hướng dẫn khám phá</button>
                <button id="btnRank" class="btn-main btn-rank" onclick="toggleTab('rankBox', this)">🏄‍♀️ Bảng xếp hạng</button>
                <button id="btnXu" class="btn-main btn-xu" onclick="toggleTab('missingBox', this)">🦀 Hoa xu chưa nhặt</button>
            </div>
        </div>
        
        <div class="right-col">
            <div id="helpBox" class="info-box active">
                <div class="help-content">
                    <p class="help-title">Aloha! Chào mừng tới Đảo Hoa Mùa Hè 🏝️</p>
                    <p>🐚 <strong>Tìm hoa:</strong> Gõ tên hoa vào ô tìm kiếm để xem ai đang sở hữu.</p>
                    <p>🏄‍♀️ <strong>Xếp hạng:</strong> Xem độ giàu có của từng người (tính từ phẩm tím trở lên).</p>
                    <p>🦀 <strong>Hoa xu:</strong> Xem danh sách các loài hoa xu mà cả hội chưa ai vớt được.</p>
                </div>
            </div>

            <div id="rankBox" class="info-box">
                <div id="mainRankArea"></div>
            </div>

            <div id="missingBox" class="info-box">
                <div id="missingArea" style="display: flex; flex-wrap: wrap; gap: 6px;"></div>
            </div>

            <div id="searchViewArea" class="info-box">
                <div class="search-title">🪸 Kết quả tìm kiếm:</div>
                <div id="searchResultArea"></div>
            </div>
        </div>
    </div>
</div>

<script>
    const URL_THANH_VIEN = "https://docs.google.com/spreadsheets/d/1tEoux6IzG80zh2oMIWLYasYziOH3bv37EGKG3UVA9WY/export?format=csv&gid=0";
    const URL_PHAM_MAU = "https://docs.google.com/spreadsheets/d/1tEoux6IzG80zh2oMIWLYasYziOH3bv37EGKG3UVA9WY/export?format=csv&gid=2019890526";

    const standardizeName = str => {
        if (!str) return '';
        let s = str.normalize('NFC').trim().toLowerCase();
        const map = { 'oà':'òa', 'oá':'óa', 'oả':'ỏa', 'oã':'õa', 'oạ':'ọa', 'oè':'òe', 'oé':'óe', 'oẻ':'ỏe', 'oẽ':'õe', 'oẹ':'ọe' };
        s = s.replace(/oà|oá|oả|oã|oạ|oè|oé|oẻ|oẽ|oẹ/g, m => map[m]);
        s = s.replace(/([^q]|^)uý/g, '$1úy').replace(/([^q]|^)uỳ/g, '$1ùy').replace(/([^q]|^)uỷ/g, '$1ủy').replace(/([^q]|^)uỹ/g, '$1ũy').replace(/([^q]|^)uỵ/g, '$1ụy');
        return s.charAt(0).toUpperCase() + s.slice(1);
    };

    const removeVietnameseTones = str => {
        if (!str) return '';
        return str.toLowerCase()
            .replace(/à|á|ạ|ả|ã|â|ầ|ấ|ậ|ẩ|ẫ|ă|ằ|ắ|ặ|ẳ|ẵ/g, "a")
            .replace(/è|é|ẹ|ẻ|ẽ|ê|ề|ế|ệ|ể|ễ/g, "e")
            .replace(/ì|í|ị|ỉ|ĩ/g, "i")
            .replace(/ò|ó|ọ|ỏ|õ|ô|ồ|ố|ộ|ổ|ỗ|ơ|ờ|ớ|ợ|ở|ỡ/g, "o")
            .replace(/ù|ú|ụ|ủ|ũ|ư|ừ|ứ|ự|ử|ữ/g, "u")
            .replace(/ỳ|ý|ỵ|ỷ|ỹ/g, "y")
            .replace(/đ/g, "d")
            .replace(/\u0300|\u0301|\u0303|\u0309|\u0323/g, "")
            .replace(/[\u02C6\u0306\u031B]/g, "")
            .trim();
    };

    function parseCSV(text) {
        let lines = text.split(/\r\n|\n/), result = [];
        for (let line of lines) {
            line = line.trim();
            if (!line) continue;
            let row = [], inQuotes = false, current = '';
            for (let c of line) {
                if (c === '"') inQuotes = !inQuotes;
                else if (c === ',' && !inQuotes) { row.push(current); current = ''; }
                else current += c;
            }
            row.push(current);
            result.push(row);
        }
        return result;
    }

    const flowerTierMap = new Map();
    const xuList = [];
    const finalMembersData = [];
    const flowerOwnersMap = new Map();
    let currentActiveTabId = 'helpBox'; 

    function getFlowerWeight(name) {
        const fData = flowerTierMap.get(name);
        const score = fData ? fData.score : 2; 
        const tierClasses = { 1: 'tier-blue', 2: 'tier-purple', 3: 'tier-orange', 4: 'tier-red' };
        return { score, className: tierClasses[score] };
    }

    async function loadDataFromGoogleSheets() {
        try {
            const [resThanhVien, resPhamMau] = await Promise.all([
                fetch(URL_THANH_VIEN).then(res => res.text()),
                fetch(URL_PHAM_MAU).then(res => res.text())
            ]);

            const phammauRows = parseCSV(resPhamMau);
            const thanhvienRows = parseCSV(resThanhVien);

            for (let i = 1; i < phammauRows.length; i++) {
                let row = phammauRows[i];
                if (row.length < 2) continue;
                let flowerName = standardizeName(row[0].replace(/^"|"$/g, ''));
                let tierStr = row[1] ? row[1].replace(/^"|"$/g, '').trim().toLowerCase() : '';
                let xuStr = row[2] ? row[2].replace(/^"|"$/g, '').trim().toLowerCase() : '';

                let score = tierStr.includes('do') ? 4 : tierStr.includes('cam') ? 3 : tierStr.includes('xanh') ? 1 : 2;
                
                flowerTierMap.set(flowerName, { score, searchKey: removeVietnameseTones(flowerName) });
                if (xuStr.includes('xu')) xuList.push(flowerName);
            }

            for (let i = 1; i < thanhvienRows.length; i++) {
                let row = thanhvienRows[i];
                if (row.length < 2) continue;
                let memberName = row[0].replace(/^"|"$/g, '').trim();
                if (!memberName) continue;

                let flowersRaw = row[1].replace(/^"|"$/g, '').split(',');
                let flowers = [...new Set(flowersRaw.map(f => standardizeName(f)))].filter(f => f);

                let totalCount = flowers.reduce((sum, f) => sum + ((flowerTierMap.get(f)?.score || 2) >= 2 ? 1 : 0), 0);
                
                const memberObj = { name: memberName, allFlowers: flowers, totalCount };
                finalMembersData.push(memberObj);

                flowers.forEach(f => {
                    if (!flowerOwnersMap.has(f)) flowerOwnersMap.set(f, []);
                    flowerOwnersMap.get(f).push(memberObj);
                });
            }

            document.getElementById('loadingArea').style.display = "none";
            document.getElementById('mainContentArea').style.display = "flex";

            initRenderRankList();
            updateMissingXu();

        } catch (error) {
            document.getElementById('loadingArea').innerHTML = "❌ Lỗi kết nối API Google Sheets. Kiểm tra quyền truy cập link.";
            console.error(error);
        }
    }

    function toggleTab(targetId, btnElement) {
        currentActiveTabId = targetId; 
        document.getElementById('flowerSearch').value = ''; 
        
        document.querySelectorAll('.info-box').forEach(box => box.classList.remove('active'));
        document.getElementById(targetId).classList.add('active');

        if(btnElement) {
            document.querySelectorAll('.btn-main').forEach(btn => btn.classList.remove('active-btn'));
            btnElement.classList.add('active-btn');
        }
    }

    function initRenderRankList() {
        const mainRankArea = document.getElementById('mainRankArea');
        mainRankArea.innerHTML = `<div class="total-badge">⚓ Tổng số: ${finalMembersData.length} thành viên</div>`;
        
        const fragment = document.createDocumentFragment();
        const container = document.createElement('div');
        container.className = "rank-list-container";
        
        const sortedRank = [...finalMembersData].sort((a, b) => b.totalCount - a.totalCount);
        const rankColors = ["#e76f51", "#f4a261", "#e9c46a", "#2a9d8f"];

        sortedRank.forEach((item, index) => {
            const collapseItem = document.createElement('div');
            const isBoy = item.name.includes("Anh Kiệt") || item.name.includes("Quốc Toàn");
            collapseItem.className = `cute-rank-item ${isBoy ? 'gentleman-card-style' : ''}`;

            const sortedFlowers = item.allFlowers.map(f => ({ name: f, ...getFlowerWeight(f) }))
                .sort((a, b) => b.score - a.score || a.name.localeCompare(b.name, 'vi'));

            let tierCounts = { 4: 0, 3: 0, 2: 0, 1: 0 };
            const chipsHtml = sortedFlowers.map(f => {
                tierCounts[f.score]++;
                return `<span class="flower-chip-item ${f.className}">${f.name}</span>`;
            }).join('');
            
            const numColor = index < 3 ? rankColors[index] : "#1d3557";

            collapseItem.innerHTML = `
                <div class="click-header-line">
                    <div class="header-left">
                        <span class="rank-number" style="color: ${numColor};">#${index + 1}</span>
                        <span>${(isBoy ? '🎩 ' : '👑 ') + item.name}</span>
                    </div>
                    <span class="count-badge">${item.totalCount} loại hoa</span>
                </div>
                <div class="rank-content-box">
                    <div class="summary-rarity-line">🌊 <strong>Kho báu:</strong> ${tierCounts[4]} Đỏ | ${tierCounts[3]} Cam | ${tierCounts[2]} Tím | <strong>${tierCounts[1]} Xanh</strong></div>
                    <div class="flower-chip-container">${chipsHtml}</div>
                </div>
            `;
            container.appendChild(collapseItem);
        });
        
        container.addEventListener('click', (e) => {
            const header = e.target.closest('.click-header-line');
            if (header) header.parentElement.classList.toggle('active-folder');
        });
        
        fragment.appendChild(container);
        mainRankArea.appendChild(fragment);
    }

    let debounceTimer;
    function searchFlowerLogic() {
        const rawInput = document.getElementById('flowerSearch').value.trim();
        if (rawInput === "") {
            document.querySelectorAll('.info-box').forEach(box => box.classList.remove('active'));
            document.getElementById(currentActiveTabId).classList.add('active');
            return;
        }

        document.querySelectorAll('.info-box').forEach(box => box.classList.remove('active'));
        document.querySelectorAll('.btn-main').forEach(btn => btn.classList.remove('active-btn'));
        document.getElementById('searchViewArea').classList.add('active');
        
        let fKeyNoTone = removeVietnameseTones(rawInput);
        const searchResultArea = document.getElementById('searchResultArea');
        
        const sortedMatches = Array.from(flowerTierMap.entries())
            .filter(([name, data]) => data.searchKey.includes(fKeyNoTone))
            .map(([name]) => name)
            .sort((a, b) => a.localeCompare(b, 'vi'));

        if (!sortedMatches.length) {
            searchResultArea.innerHTML = `<div class="single-flower-block flower-not-found">❌ Rạn san hô này chưa có loài hoa "${rawInput}"</div>`;
            return;
        }

        // Logic bổ sung hiển thị Phẩm màu hoa khi tìm kiếm
        searchResultArea.innerHTML = sortedMatches.map(name => {
            const owners = (flowerOwnersMap.get(name) || [])
                .sort((a, b) => a.totalCount - b.totalCount)
                .map(m => m.name);

            // Lấy điểm (từ 1 đến 4) của loại hoa này
            const fData = flowerTierMap.get(name);
            const score = fData ? fData.score : 2;
            
            // Map để lấy chữ hiển thị và class theo điểm phẩm chất
            const tierInfo = {
                4: { text: "Hoa phẩm Đỏ", colorClass: "text-tier-red", boxClass: "box-tier-red" },
                3: { text: "Hoa phẩm Cam", colorClass: "text-tier-orange", boxClass: "box-tier-orange" },
                2: { text: "Hoa phẩm Tím", colorClass: "text-tier-purple", boxClass: "" },
                1: { text: "Hoa phẩm Xanh", colorClass: "text-tier-blue", boxClass: "" }
            };
            
            const tierStr = tierInfo[score].text;
            const tierColor = tierInfo[score].colorClass;
            const glowBox = tierInfo[score].boxClass; // Kích hoạt viền sáng bừng cho ô tìm kiếm nếu là hoa Đỏ/Cam

            return owners.length 
                ? `<div class="single-flower-block flower-found ${glowBox}">🌸 <strong>${name}</strong> - <span class="${tierColor}">[${tierStr}]</span> có <strong>${owners.length}</strong> thành viên (Xếp từ ít hoa nhất 👇):<br>👉 <em>${owners.join(', ')}</em></div>`
                : `<div class="single-flower-block flower-empty ${glowBox}">🌸 <strong>${name}</strong> - <span class="${tierColor}">[${tierStr}]</span>: Cả đảo chưa ai vớt được.</div>`;
        }).join('');
    }

    document.getElementById('flowerSearch').addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(searchFlowerLogic, 300);
    });

    function updateMissingXu() {
        const ownedSet = new Set();
        finalMembersData.forEach(m => m.allFlowers.forEach(f => ownedSet.add(f)));
        const uniqueMissing = xuList.filter(f => !ownedSet.has(f)).sort((a, b) => a.localeCompare(b, 'vi'));
        
        const missingArea = document.getElementById('missingArea');
        if (uniqueMissing.length === 0) {
            missingArea.innerHTML = `<div class="all-cleared-msg">🎉 Đã đổi hết hoa xu đến hiện tại, mọi người cần thì trade hoa với nhau nhé ^^ 🌸</div>`;
        } else {
            missingArea.innerHTML = uniqueMissing.map(item => `<span class="xu-missing-badge">${item}</span>`).join('');
        }
    }

    loadDataFromGoogleSheets();
</script>
</body>
</html>
