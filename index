<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌸 Queenss Garden 👑</title>
    <!-- Đổi sang Font Quicksand tròn trịa, dễ thương chuẩn gu phái nữ -->
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Quicksand', sans-serif; }
        body { 
            background: #fff0f3; 
            background-image: radial-gradient(#ffccd5 1.5px, transparent 1.5px);
            background-size: 20px 20px;
            padding: 30px 20px; 
            display: flex; 
            justify-content: center; 
            min-height: 100vh; 
        }

        /* ----- MAIN UI STYLES ----- */
        .garden-container { 
            width: 100%; 
            max-width: 500px; 
            background: rgba(255, 255, 255, 0.98); 
            padding: 35px 25px; 
            border-radius: 40px; 
            box-shadow: 0 20px 50px rgba(255, 143, 163, 0.4); 
            border: 5px double #ffb3c1; 
            display: flex; 
            flex-direction: column; 
            position: relative; 
        }
        .decor-ribbon { position: absolute; top: -16px; font-size: 24px; animation: floatRibbon 3s ease-in-out infinite alternate; }
        .decor-ribbon.left { left: 30px; }
        .decor-ribbon.right { right: 30px; animation-delay: 0.5s; }
        
        /* Hiệu ứng ribbon nhấp nhô nhẹ */
        @keyframes floatRibbon {
            0% { transform: translateY(0); }
            100% { transform: translateY(-4px); }
        }

        .search-box { 
            background: linear-gradient(135deg, #fff5f6, #fff0f3); 
            border: 2.5px dashed #ff758f; 
            padding: 18px; 
            border-radius: 28px; 
            margin-bottom: 25px; 
            box-shadow: 0 8px 20px rgba(255, 117, 143, 0.08); 
        }
        .search-box-title { font-size: 13px; font-weight: 700; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #c9184a; display: flex; align-items: center; gap: 6px; }
        .search-input { 
            width: 100%; 
            padding: 14px 18px; 
            font-size: 14px; 
            border-radius: 20px; 
            border: 2px solid #ffccd5; 
            outline: none; 
            background: #fff; 
            color: #4a4a4a; 
            transition: all 0.3s ease;
        }
        .search-input:focus {
            border-color: #ff4d6d;
            box-shadow: 0 0 10px rgba(255, 77, 109, 0.25);
        }

        /* Hiệu ứng nảy kẹo ngọt khi Hover nút bấm */
        .btn-main { 
            width: 100%; 
            padding: 16px 20px; 
            font-size: 14px; 
            font-weight: 700; 
            border: none; 
            border-radius: 25px; 
            cursor: pointer; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            gap: 8px; 
            user-select: none; 
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .btn-main:hover {
            transform: translateY(-4px) scale(1.02);
            filter: brightness(1.05);
        }
        .btn-main:active {
            transform: translateY(-1px) scale(0.98);
        }

        .btn-help { color: #fff; background: linear-gradient(135deg, #ffca3a, #ff9f1c); box-shadow: 0 6px 15px rgba(255, 159, 28, 0.3); }
        .btn-rank { color: #fff; background: linear-gradient(135deg, #ff85a1, #ff4d6d); box-shadow: 0 6px 15px rgba(255, 77, 109, 0.3); }
        .btn-xu { color: #245500; background: linear-gradient(135deg, #9ef01a, #70e000); box-shadow: 0 6px 15px rgba(112, 224, 0, 0.3); }

        .info-box { margin-top: 8px; padding: 20px; background: rgba(255, 253, 253, 0.95); border: 2px dashed #ffccd5; border-radius: 28px; display: none; box-shadow: 0 10px 25px rgba(255, 182, 193, 0.15); }
        .help-content { color: #5c5757; font-size: 13.5px; line-height: 1.8; }
        .help-content p { margin-bottom: 4px; }
        .help-content .help-title { margin-bottom: 10px; font-weight: 600; color: #ff4d6d; }

        /* ----- RANKING LIST STYLES ----- */
        .total-badge { font-size: 12.5px; font-weight: 700; color: #40916c; margin-bottom: 14px; background: #d8f3dc; padding: 6px 14px; border-radius: 12px; display: inline-block; border: 1px solid #b7e4c7; }
        .rank-list-container { display: flex; flex-direction: column; gap: 12px; width: 100%; }
        
        .cute-rank-item { 
            border: 2px solid #ffe3e8; 
            border-radius: 22px; 
            overflow: hidden; 
            background: #fff; 
            box-shadow: 0 5px 12px rgba(255, 182, 193, 0.1); 
            transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1); 
        }
        .cute-rank-item:hover {
            transform: scale(1.015);
            border-color: #ff85a1;
            box-shadow: 0 8px 22px rgba(255, 133, 161, 0.2);
        }
        .gentleman-card-style.cute-rank-item { border-color: #e0f2fe; box-shadow: 0 5px 12px rgba(0, 48, 73, 0.04); }
        .gentleman-card-style.cute-rank-item:hover {
            border-color: #bae6fd;
            box-shadow: 0 8px 22px rgba(56, 189, 248, 0.15);
        }

        .click-header-line { display: flex; justify-content: space-between; align-items: center; padding: 15px 18px; cursor: pointer; user-select: none; transition: background 0.2s; }
        .click-header-line:hover { background: #fff5f6; }
        .gentleman-card-style .click-header-line:hover { background: #f0f9ff; }

        .active-folder .click-header-line { background: #fff0f3 !important; color: #ff4d6d !important; }
        .active-folder.gentleman-card-style .click-header-line { background: #e0f2fe !important; color: #003049 !important; }

        .header-left { display: flex; align-items: center; gap: 10px; font-size: 14px; color: #4a4a4a; }
        .gentleman-card-style .header-left { color: #003049; font-weight: 700; }
        .rank-number { font-weight: 700; width: 24px; text-align: center; font-size: 15px; }

        .count-badge { font-weight: 700; padding: 6px 14px; border-radius: 20px; font-size: 11.5px; color: #ff4d6d; background: #fff5f6; border: 1px solid #ffccd5; }
        .gentleman-card-style .count-badge { color: #003049; background: #e0f2fe; border: 1px solid #bae6fd; }

        .rank-content-box { display: none; padding: 18px; background: #fffdfd; border-top: 2px dashed #fff0f2; }
        .active-folder .rank-content-box { display: block !important; }
        .active-folder.gentleman-card-style .rank-content-box { background: #fcfdfe !important; border-top: 2px dashed #bae6fd !important; }

        .summary-rarity-line { font-size: 12.5px; padding: 8px 12px; margin-bottom: 12px; border-radius: 12px; background: #fff5f6; border-left: 4px solid #ff4d6d; color: #4a4a4a; font-weight: 600; line-height: 1.5; }
        .gentleman-card-style .summary-rarity-line { background: #f0f9ff !important; border-left-color: #3b82f6 !important; }

        .flower-chip-container { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 8px; }
        
        /* Hiệu ứng kẹo dẻo phát sáng nhẹ cho các tag hoa */
        .flower-chip-item { 
            display: inline-block; 
            padding: 6px 12px; 
            border-radius: 14px; 
            font-size: 11.5px; 
            margin: 3px; 
            transition: transform 0.2s;
            cursor: default;
        }
        .flower-chip-item:hover { transform: scale(1.08) translateY(-1px); }
        
        .xu-missing-badge { display: inline-block; padding: 6px 12px; border-radius: 14px; font-size: 11.5px; background: #fff; border: 1px solid #ffccd5; color: #a4133c; font-weight: 600; margin: 3px; transition: all 0.2s; }
        .xu-missing-badge:hover { transform: scale(1.08); background: #fff5f6; border-color: #ff4d6d; }

        /* ----- TIERS CODES ----- */
        .tier-green { background: linear-gradient(135deg, #ebfbee 0%, #cbf3d6) !important; border: 1px solid #b7e4c7 !important; color: #2d6a4f !important; font-weight: 600; }
        .tier-purple { background: linear-gradient(135deg, #f3f0ff 0%, #eebefa) !important; border: 1px solid #d0bfff !important; color: #5f3dc4 !important; font-weight: 600; }
        .tier-orange { background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%) !important; border: 1.5px solid #ff9800 !important; color: #e65100 !important; font-weight: 700 !important; box-shadow: 0 3px 6px rgba(255, 152, 0, 0.15) !important; }
        .tier-pink { background: linear-gradient(135deg, #fff0f6 0%, #ffdeeb 100%) !important; border: 2px solid #ff85a1 !important; color: #a4133c !important; font-weight: 700 !important; box-shadow: 0 4px 10px rgba(255, 133, 161, 0.25) !important; }

        /* ----- SEARCH AREA ----- */
        .search-title { font-size: 13.5px; font-weight: 700; color: #5c677d; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; gap: 4px; }
        .single-flower-block { padding: 18px; border-radius: 24px; font-size: 14px; line-height: 1.6; margin-bottom: 14px; transition: transform 0.2s; }
        .single-flower-block:hover { transform: translateY(-2px); }
        .flower-found { border: 2.5px solid #ffccd5; background: #fff5f6; color: #b7094c; box-shadow: 0 8px 20px rgba(255,182,193,0.18); }
        .flower-empty { border: 2.5px solid #dee2e6; background: #fafafa; color: #888; }
        .flower-not-found { border: 2.5px solid #dee2e6; background: #fafafa; color: #999; text-align: center; }
    </style>
</head>
