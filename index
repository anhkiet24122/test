<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌊 Queenss Garden - Summer Sea 🏝️</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght=400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* ----- HỆ THỐNG BIẾN MÀU ĐẠI DƯƠNG MÙA HÈ ----- */
        :root {
            --sea-bg: #e0f2fe; /* Màu nước biển nông trong vắt */
            --sea-dot: #bae6fd; /* Bọt sóng biển nhạt */
            --sea-border: #4ea8de; /* Màu xanh sóng dương */
            --sea-main: #0077b6; /* Xanh đại dương thanh mát */
            --sea-dark: #03045e; /* Xanh lục địa sâu thẳm */
            
            --text-dark: #1c2541;
            --text-gray: #475569;
            
            --boy-bg: #e0f2fe;
            --boy-border: #74c69d;
            --boy-text: #03045e;
            
            --box-bg: rgba(255, 255, 255, 0.97);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Be Vietnam Pro', sans-serif; }
        
        body { 
            background: var(--sea-bg); 
            background-image: radial-gradient(var(--sea-dot) 1.5px, transparent 1.5px);
            background-size: 20px 20px;
            padding: 30px 20px; 
            display: flex; 
            justify-content: center; 
            min-height: 100vh; 
        }

        /* ----- HIỆU ỨNG CHUYỂN ĐỘNG MƯỢT MÀ ----- */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @keyframes scaleUp {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }

        /* ----- MAIN UI STYLES ----- */
        .garden-container { 
            width: 100%; max-width: 500px; 
            background: var(--box-bg); 
            padding: 35px 25px; border-radius: 40px; 
            box-shadow: 0 20px 45px rgba(0, 119, 182, 0.15); 
            border: 5px double var(--sea-border); 
            display: flex; flex-direction: column; position: relative; 
            animation: fadeInDown 0.6s ease-out;
        }
        
        .decor-ribbon { position: absolute; top: -16px; font-size: 24px; transition: transform 0.3s; }
        .decor-ribbon:hover { transform: scale(1.2) rotate(10deg); }
        .decor-ribbon.left { left: 30px; }
        .decor-ribbon.right { right: 30px; }
        
        .search-box { 
            background: linear-gradient(135deg, #f0fafd, var(--sea-bg)); 
            border: 2.5px dashed var(--sea-border); padding: 18px; border-radius: 28px; margin-bottom: 25px; 
            box-shadow: inset 0 4px 10px rgba(0, 119, 182, 0.03); 
        }
        .search-box-title { font-size: 12px; font-weight: 700; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: var(--sea-dark); display: flex; align-items: center; gap: 6px; }
        .search-input { 
            width: 100%; padding: 14px 18px; font-size: 14px; border-radius: 20px; 
            border: 2px solid var(--sea-dot); outline: none; background: #fff; color: var(--text-dark); 
            transition: border-color 0.3s, box-shadow 0.3s;
        }
        .search-input:focus { border-color: var(--sea-main); box-shadow: 0 0 10px rgba(0, 119, 182, 0.2); }

        .btn-main { 
            width: 100%; padding: 16px 20px; font-size: 14px; font-weight: 700; border: none; 
            border-radius: 25px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; 
            user-select: none; transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        .btn-main:hover { transform: translateY(-3px); filter: brightness(1.05); }
        .btn-main:active { transform: translateY(1px); }
        
        .btn-help { color: #5c3d00; background: linear-gradient(135deg, #ffe082, #ffb300); box-shadow: 0 6px 15px rgba(255, 179, 0, 0.25); }
        .btn-rank { color: #fff; background: linear-gradient(135deg, #4ea8de, var(--sea-main)); box-shadow: 0 6px 15px rgba(0, 119, 182, 0.3); }
        .btn-xu { color: #fff; background: linear-gradient(135deg, #52b788, #2d6a4f); box-shadow: 0 6px 15px rgba(45, 106, 79, 0.25); }

        .info-box { 
            margin-top: 8px; padding: 20px; background: rgba(252, 254, 255, 0.98); 
            border: 2px dashed var(--sea-dot); border-radius: 28px; display: none; 
            animation: scaleUp 0.3s ease-out;
        }
        .help-content { color: var(--text-gray); font-size: 13px; line-height: 1.8; }
        .help-content p { margin-bottom: 4px; }
        .help-content .help-title { margin-bottom: 10px; font-weight: 500; color: var(--sea-main); }

        /* ----- RANKING LIST STYLES ----- */
        .total-badge { font-size: 12px; font-weight: 700; color: #0077b6; margin-bottom: 14px; background: #e0f2fe; padding: 6px 14px; border-radius: 12px; display: inline-block; border: 1px solid #bae6fd; }
        .rank-list-container { display: flex; flex-direction: column; gap: 12px; width: 100%; }
        
        .cute-rank-item { border: 1px solid #e2f1f7; border-radius: 20px; overflow: hidden; background: #fff; box-shadow: 0 4px 10px rgba(0, 119, 182, 0.04); transition: all 0.3s ease; }
        .gentleman-card-style.cute-rank-item { border-color: #a8dadc; box-shadow: 0 4px 10px rgba(3, 4, 94, 0.04); }

        .click-header-line { display: flex; justify-content: space-between; align-items: center; padding: 15px 18px; cursor: pointer; user-select: none; transition: background 0.3s; }
        .click-header-line:hover { background: #f7fcfe; }
        
        .active-folder .click-header-line { background: #f0fafd !important; color: var(--sea-main) !important; }
        .active-folder.gentleman-card-style .click-header-line { background: #edf6f9 !important; color: var(--sea-dark) !important; }

        .header-left { display: flex; align-items: center; gap: 10px; font-size: 13.5px; color: var(--text-dark); transition: color 0.3s; font-weight: 500; }
        .rank-number { font-weight: 700; width: 24px; text-align: center; }

        .count-badge { font-weight: 700; padding: 5px 12px; border-radius: 20px; font-size: 11px; color: var(--sea-main); background: #f0fafd; border: 1px solid var(--sea-dot); transition: all 0.3s; }
        .gentleman-card-style .count-badge { color: #2d6a4f; background: #e8f5e9; border: 1px solid #c8e6c9; }

        .rank-content-box { display: none; padding: 18px; background: #fffdfd; border-top: 1px solid #f0fafd; animation: fadeInDown 0.3s ease-out; }
        .active-folder .rank-content-box { display: block !important; }

        .summary-rarity-line { font-size: 12px; padding: 8px 12px; margin-bottom: 12px; border-radius: 12px; background: #f0fafd; border-left: 4px solid var(--sea-main); color: var(--text-dark); font-weight: 500; line-height: 1.5; }

        .flower-chip-container { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 8px; }
        .flower-chip-item { display: inline-block; padding: 6px 12px; border-radius: 14px; font-size: 11.5px; margin: 3px; transition: transform 0.2s; }
        .flower-chip-item:hover { transform: scale(1.05); }
        
        .xu-missing-badge { display: inline-block; padding: 6px 12px; border-radius: 14px; font-size: 11.5px; background: #fff; border: 1px solid var(--sea-dot); color: var(--sea-dark); font-weight: 500; margin: 3px; transition: transform 0.2s; }
        .xu-missing-badge:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0, 119, 182, 0.1); }

        /* ----- TIERS PHẨM CHẤT HOA ----- */
        .tier-green { background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9) !important; border: 1px solid #a8dadc !important; color: #2e7d32 !important; font-weight: 500; }
        .tier-purple { background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7) !important; border: 1px solid #d1c4e9 !important; color: #6a1b9a !important; font-weight: 500; }
        .tier-orange { background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2) !important; border: 1.5px solid #ffa726 !important; color: #e65100 !important; font-weight: 600 !important; }
        .tier-pink { background: linear-gradient(135deg, #ffe0e6 0%, #ffb3c1) !important; border: 2px solid #ff4d6d !important; color: #c9184a !important; font-weight: 700 !important; box-shadow: 0 2px 6px rgba(255, 77, 109, 0.15) !important; }

        /* ----- SEARCH AREA ----- */
        .search-title { font-size: 13px; font-weight: 700; color: var(--text-gray); margin-bottom: 15px; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; gap: 4px; }
        .single-flower-block { padding: 18px; border-radius: 24px; font-size: 13.5px; line-height: 1.6; margin-bottom: 14px; animation: fadeInDown 0.3s ease-out; }
        .flower-found { border: 2.5px solid var(--sea-dot); background: #f0fafd; color: var(--sea-dark); box-shadow: 0 6px 15px rgba(0,119,182,0.06); }
        .flower-empty { border: 2.5px solid #dee2e6; background: #fafafa; color: #888; }
        .flower-not-found { border: 2.5px solid #dee2e6; background: #fafafa; color: #999; text-align: center; }
    </style>
</head>
