    // --- 2. HỆ THỐNG TRA CỨU TỐI ƯU ---
    const xuList = [...new Set(rawXuList.map(standardizeName))];
    const pinkList = rawPinkList.map(standardizeName);
    const orangeList = rawOrangeList.map(standardizeName);
    const purpleList = rawPurpleList.map(standardizeName);
    const greenList = rawGreenList.map(standardizeName);

    const membersDataProcessed = rawMembers.map(m => ({
        name: m.name,
        flowers: [...new Set(m.flowers.map(standardizeName))]
    }));

    const flowerTierMap = new Map();
    pinkList.forEach(f => flowerTierMap.set(f, 4));
    orangeList.forEach(f => flowerTierMap.set(f, 3));
    purpleList.forEach(f => flowerTierMap.set(f, 2));
    greenList.forEach(f => flowerTierMap.set(f, 1));

    function getFlowerWeight(name) {
        const score = flowerTierMap.get(name) || 2; 
        const tierClasses = { 1: 'tier-green', 2: 'tier-purple', 3: 'tier-orange', 4: 'tier-pink' };
        return { score, className: tierClasses[score] };
    }

    const flowerOwnersMap = new Map();
    const allKnownFlowers = new Set([...xuList, ...pinkList, ...orangeList, ...purpleList, ...greenList]);
    allKnownFlowers.forEach(f => flowerOwnersMap.set(f, []));

    const finalMembersData = membersDataProcessed.map(item => {
        const totalCount = item.flowers.filter(f => (flowerTierMap.get(f) || 2) >= 2).length;
        const memberObj = { name: item.name, allFlowers: item.flowers, totalCount };
        
        item.flowers.forEach(f => {
            if (!flowerOwnersMap.has(f)) flowerOwnersMap.set(f, []);
            flowerOwnersMap.get(f).push(memberObj);
        });

        return memberObj;
    });

    // --- 3. CÁC HÀM XỬ LÝ CHỨC NĂNG ---
    const mainRankArea = document.getElementById('mainRankArea');
    const searchResultArea = document.getElementById('searchResultArea');
    const missingArea = document.getElementById('missingArea');
    const missingBox = document.getElementById('missingBox');
    const rankBox = document.getElementById('rankBox');
    const helpBox = document.getElementById('helpBox');
    const flowerInput = document.getElementById('flowerSearch');
    const defaultGardenWidgets = document.getElementById('defaultGardenWidgets');
    const searchViewArea = document.getElementById('searchViewArea');

    function initRenderRankList() {
        mainRankArea.innerHTML = `<div class="total-badge">🌱 Tổng số: ${finalMembersData.length} thành viên</div>`;
        const container = document.createElement('div');
        container.className = "rank-list-container";

        const sortedRank = [...finalMembersData].sort((a, b) => b.totalCount - a.totalCount);
        const rankColors = ["#0077b6", "#0096c7", "#00b4d8", "#90e0ef"];

        sortedRank.forEach((item, index) => {
            const collapseItem = document.createElement('div');
            
            const isBoy = item.name === "Cá chiên (Anh Kiệt)" || item.name === "ChồgcủaHạDi (Quốc Toàn)";
            collapseItem.className = isBoy ? "cute-rank-item gentleman-card-style" : "cute-rank-item";

            const sortedFlowersWithTier = item.allFlowers.map(f => ({ name: f, ...getFlowerWeight(f) }))
                .sort((a, b) => b.score - a.score || a.name.localeCompare(b.name, 'vi'));

            let tierCounts = { 4: 0, 3: 0, 2: 0, 1: 0 };
            const chipsHtml = sortedFlowersWithTier.map(f => {
                tierCounts[f.score]++;
                return `<span class="flower-chip-item ${f.className}">${f.name}</span>`;
            }).join('');
            
            const summaryHtml = `<div class="summary-rarity-line">🌊 <strong>Đội hình tính điểm:</strong> ${tierCounts[4]} Hồng | ${tierCounts[3]} Cam | ${tierCounts[2]} Tím</div>`;
            const numColor = index < 3 ? rankColors[index] : "#64748b";

            collapseItem.innerHTML = `
                <div class="click-header-line">
                    <div class="header-left">
                        <span class="rank-number" style="color: ${numColor};">#${index + 1}</span>
                        <span class="member-display-name"></span>
                    </div>
                    <span class="count-badge">${item.totalCount} loại hoa</span>
                </div>
                <div class="rank-content-box">
                    ${summaryHtml}
                    <div class="flower-chip-container">${chipsHtml}</div>
                </div>
            `;

            // Gán trực tiếp qua textContent để giữ nguyên dấu ngoặc () của Đạo Chích (Trúc Linh)
            collapseItem.querySelector('.member-display-name').textContent = (isBoy ? '🎩 ' : '👑 ') + item.name;

            collapseItem.querySelector('.click-header-line').addEventListener('click', () => collapseItem.classList.toggle('active-folder'));
            container.appendChild(collapseItem);
        });
        mainRankArea.appendChild(container);
    }

    let debounceTimer;
    function searchFlowerLogic() {
        const rawInput = flowerInput.value.trim();
        if (rawInput === "") {
            searchViewArea.style.display = "none";
            defaultGardenWidgets.style.display = "flex";
            return;
        }

        let fKey = standardizeName(rawInput).toLowerCase();

        defaultGardenWidgets.style.display = "none";
        searchViewArea.style.display = "block";
        
        const sortedMatches = Array.from(flowerOwnersMap.keys())
            .filter(name => name.toLowerCase().includes(fKey))
            .sort((a, b) => a.localeCompare(b, 'vi'));

        if (!sortedMatches.length) {
            searchResultArea.innerHTML = `<div class="single-flower-block flower-not-found">❌ Không tìm thấy loại hoa nào chứa từ khóa "${rawInput}"</div>`;
            return;
        }

        searchResultArea.innerHTML = sortedMatches.map(name => {
            const owners = (flowerOwnersMap.get(name) || [])
                .sort((a, b) => a.totalCount - b.totalCount)
                .map(m => m.name);

            return owners.length 
                ? `<div class="single-flower-block flower-found">🌸 <strong>${name}</strong> hiện có <strong>${owners.length}</strong> thành viên sở hữu (Xếp từ ít hoa nhất 👇):<br>👉 <em>${owners.join(', ')}</em></div>`
                : `<div class="single-flower-block flower-empty">🌸 <strong>${name}</strong>: Hiện chưa có thành viên nào sở hữu.</div>`;
        }).join('');
    }

    flowerInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(searchFlowerLogic, 300);
    });

    function updateMissingXu() {
        const ownedSet = new Set();
        finalMembersData.forEach(m => m.allFlowers.forEach(f => ownedSet.add(f)));
        
        const uniqueMissing = xuList.filter(f => !ownedSet.has(f)).sort((a, b) => a.localeCompare(b, 'vi'));
        missingArea.innerHTML = uniqueMissing.map(item => `<span class="xu-missing-badge">${item}</span>`).join('');
    }

    const toggleBox = (showBox, hideBox1, hideBox2) => {
        if (showBox.style.display === "block") {
            showBox.style.display = "none";
        } else {
            showBox.style.display = "block";
            hideBox1.style.display = "none";
            hideBox2.style.display = "none";
        }
    };

    document.getElementById('btnHelp').addEventListener('click', () => toggleBox(helpBox, rankBox, missingBox));
    document.getElementById('btnRank').addEventListener('click', () => toggleBox(rankBox, helpBox, missingBox));
    document.getElementById('btnXu').addEventListener('click', () => toggleBox(missingBox, helpBox, rankBox));

    initRenderRankList();
    updateMissingXu();
</script>
