<div class="garden-container">
    <span class="decor-ribbon left">🌊</span>
    <span class="decor-ribbon right">🌊</span>

    <h2 style="text-align: center; color: var(--sea-main); margin-bottom: 20px;">🌊 Queenss Garden 🏝️</h2>
    
    <div class="search-box">
        <div class="search-box-title">🌱 Tìm theo tên hoa:</div>
        <input type="text" id="flowerSearch" class="search-input" placeholder="Nhập tên hoa muốn tra cứu...">
    </div>
    
    <div style="flex-grow: 1;">
