    const rawXuList = ["Thục quỳ đỏ", "Thục quỳ hồng", "Thục quỳ vàng", "Thanh cúc lam", "Mạch môn tím", "Hoa sao nhái trắng", "Hoa baby hồng", "Hoa baby lam", "Hoa lồng đèn đỏ", "Vạn tuế lá xanh", "Trúc đào đỏ tím", "Hải đường đỏ", "Hải đường vàng", "Đỗ quyên hồng", "Đỗ quyên vàng", "Đỗ quyên đỏ", "Tử linh lan hồng", "Tử linh lan đỏ", "Tử linh lan tím", "Hồng jacqueline trắng", "Hoa thuý châu tím", "Hoa thuý châu trắng", "Ghim cài lửa", "Ghim cài vàng mật", "Huệ hosta lam", "Hoa báo xuân hồng", "Hoa huyên tím trắng", "Hoa anh thảo tím nhạt", "Hoa anh thảo xanh nhạt", "Hoa anh thảo hồng nhạt", "Huệ hosta tím", "Nhài nhật", "Lan phượng vĩ đỏ", "Mạch môn hồng phấn", "Hoa lộ vi vàng", "Hoa lộ vi trắng", "Cúc thược dược cam", "Cúc thược dược đen", "Lan vũ nữ vàng", "Hoa poppy himalaya vàng", "Hoa poppy himalaya xanh", "Hoa phi yến tím", "Hoa anh thảo vàng", "Hồng lenten vàng", "Cây sống đời đỏ", "Cây sống đời vàng", "Mộc hương vàng", "Mộc hương trắng", "Thược dược đỏ", "Lay ơn tím", "Tường vi hồng", "Lay ơn trắng", "Hải quỳ cam", "San hô cam", "Hải quỳ đỏ", "Hoa hải quỳ tím", "Hoa hải quỳ hồng", "Hoa hải quỳ trắng", "Thược dược trắng", "Hồng môn phấn", "Thanh cúc tím", "Lạc tân phụ lam", "Lạc tân phụ đỏ", "Lạc tân phụ tím", "Tỏi trời", "Trúc đào hồng nhạt", "Địa lan trắng", "Hoa hành tím", "Diên vĩ đức trắng vàng", "Hồng lenten đỏ", "Mộc hương cam", "Vạn tuế lá lam", "Thanh cúc hồng", "Hoa baby trắng", "San hô tím", "Hoa báo xuân vàng", "Me đất cam vàng", "Thược dược dương xỉ hồng đào", "Thược dược dương xỉ đỏ tươi", "Ghim cài hồng hạnh", "Hoa hồng sa mạc hồng nhạt"];

    const redList = rawRedList.map(standardizeName);
    const orangeList = rawOrangeList.map(standardizeName);
    const purpleList = rawPurpleList.map(standardizeName);
    const blueList = rawBlueList.map(standardizeName);
    const xuList = [...new Set(rawXuList.map(standardizeName))];

    const flowerTierMap = new Map();
    redList.forEach(f => flowerTierMap.set(f, 4));
    orangeList.forEach(f => flowerTierMap.set(f, 3));
    purpleList.forEach(f => flowerTierMap.set(f, 2));
    blueList.forEach(f => flowerTierMap.set(f, 1));

    function getFlowerWeight(name) {
        const score = flowerTierMap.get(name) || 2; 
        const tierClasses = { 1: 'tier-blue', 2: 'tier-purple', 3: 'tier-orange', 4: 'tier-red' };
        return { score, className: tierClasses[score] };
    }

    // Các biến lưu trữ dữ liệu toàn cục sau khi tải từ Sheet
    let finalMembersData = [];
    let flowerOwnersMap = new Map();
    const allKnownFlowers = new Set([...xuList, ...redList, ...orangeList, ...purpleList, ...blueList]);

    // ----- DOM ELEMENTS -----
    const mainRankArea = document.getElementById('mainRankArea');
    const searchResultArea = document.getElementById('searchResultArea');
    const missingArea = document.getElementById('missingArea');
    const missingBox = document.getElementById('missingBox');
    const rankBox = document.getElementById('rankBox');
    const helpBox = document.getElementById('helpBox');
    const flowerInput = document.getElementById('flowerSearch');
    const defaultGardenWidgets = document.getElementById('defaultGardenWidgets');
    const searchViewArea = document.getElementById('searchViewArea');

    // ----- LẤY DỮ LIỆU TỪ GOOGLE SHEET -----
    async function loadDataFromSheet() {
        if (!GOOGLE_SHEET_API_URL || GOOGLE_SHEET_API_URL === "https://script.google.com/macros/s/AKfycbzdVPxV9gHIiHMlzh48wcD4bSbIcI-2D1GlDvfO0Vb6o68jRHOqxnsrPDg8QUA46rt8Sg/exec") {
            mainRankArea.innerHTML = `<div style="text-align: center; color: #e63946; font-weight: bold;">❌ Bạn chưa dán Link API Google Sheet vào code!</div>`;
            return;
        }

        try {
            const response = await fetch(GOOGLE_SHEET_API_URL);
            const rawMembers = await response.json();
            
            // Xử lý dữ liệu vừa tải về
            const membersDataProcessed = rawMembers.map(m => ({
                name: m.name,
                flowers: [...new Set(m.flowers.map(standardizeName))]
            }));

            // Reset map hoa
            flowerOwnersMap.clear();
            allKnownFlowers.forEach(f => flowerOwnersMap.set(f, []));

            finalMembersData = membersDataProcessed.map(item => {
                const totalCount = item.flowers.filter(f => (flowerTierMap.get(f) || 2) >= 2).length;
                const memberObj = { name: item.name, allFlowers: item.flowers, totalCount };
                
                item.flowers.forEach(f => {
                    if (!flowerOwnersMap.has(f)) flowerOwnersMap.set(f, []);
                    flowerOwnersMap.get(f).push(memberObj);
                });

                return memberObj;
            });

            // Sau khi có data, render lại UI và mở khóa ô tìm kiếm
            initRenderRankList();
            updateMissingXu();
            flowerInput.disabled = false;

        } catch (error) {
            mainRankArea.innerHTML = `<div style="text-align: center; color: #e63946; font-weight: bold;">❌ Đã xảy ra lỗi khi tải dữ liệu từ bãi biển! Vui lòng tải lại trang.</div>`;
            console.error("Lỗi fetch dữ liệu: ", error);
        }
    }

    // ----- RENDER BẢNG XẾP HẠNG -----
    function initRenderRankList() {
        mainRankArea.innerHTML = `<div class="total-badge">⚓ Tổng số: ${finalMembersData.length} thành viên</div>`;
        const container = document.createElement('div');
        container.className = "rank-list-container";

        const sortedRank = [...finalMembersData].sort((a, b) => b.totalCount - a.totalCount);
        const rankColors = ["#e76f51", "#f4a261", "#e9c46a", "#2a9d8f"];

        sortedRank.forEach((item, index) => {
            const collapseItem = document.createElement('div');
            const isBoy = item.name === "Cá chiên (Anh Kiệt)" || item.name === "ChồgcủaHạDi (Quốc Toàn)";
            collapseItem.className = isBoy ? "cute-rank-item gentleman-card-style" : "cute-rank-item";

            const sortedFlowersWithTier = item.allFlowers
                .map(f => ({ name: f, ...getFlowerWeight(f) }))
                .sort((a, b) => b.score - a.score || a.name.localeCompare(b.name, 'vi'));

            let tierCounts = { 4: 0, 3: 0, 2: 0, 1: 0 };
            const chipsHtml = sortedFlowersWithTier.map(f => {
                tierCounts[f.score]++;
                return `<span class="flower-chip-item ${f.className}">${f.name}</span>`;
            }).join('');
            
            const summaryHtml = `<div class="summary-rarity-line">🌊 <strong>Kho báu:</strong> ${tierCounts[4]} Đỏ | ${tierCounts[3]} Cam | <strong>${tierCounts[2]} Tím</strong> | ${tierCounts[1]} Xanh</div>`;
            const numColor = index < 3 ? rankColors[index] : "#1d3557";
            
            collapseItem.innerHTML = `
                <div class="click-header-line">
                    <div class="header-left">
                        <span class="rank-number" style="color: ${numColor};">#${index + 1}</span>
                        <span class="member-display-name">${(isBoy ? '🎩 ' : '👑 ') + item.name}</span>
                    </div>
                    <span class="count-badge">${item.totalCount} loại hoa (từ Tím)</span>
                </div>
                <div class="rank-content-box">
                    ${summaryHtml}
                    <div class="flower-chip-container">${chipsHtml}</div>
                </div>
            `;
            container.appendChild(collapseItem);
        });

        container.addEventListener('click', (e) => {
            const headerBtn = e.target.closest('.click-header-line');
            if (headerBtn) headerBtn.parentElement.classList.toggle('active-folder');
        });
        mainRankArea.appendChild(container);
    }

    // ----- TÌM KIẾM HOA -----
    let debounceTimer;
    function searchFlowerLogic() {
        const rawInput = flowerInput.value.trim();
        if (!rawInput) {
            searchViewArea.style.display = "none";
            defaultGardenWidgets.style.display = "flex";
            return;
        }

        const fKeyNoTone = removeVietnameseTones(rawInput);
        defaultGardenWidgets.style.display = "none";
        searchViewArea.style.display = "block";
        
        const sortedMatches = Array.from(flowerOwnersMap.keys())
            .filter(name => removeVietnameseTones(name).includes(fKeyNoTone))
            .sort((a, b) => a.localeCompare(b, 'vi'));

        if (!sortedMatches.length) {
            searchResultArea.innerHTML = `<div class="single-flower-block flower-not-found">❌ Rạn san hô này chưa có loài hoa "${rawInput}"</div>`;
            return;
        }

        searchResultArea.innerHTML = sortedMatches.map(name => {
            const owners = (flowerOwnersMap.get(name) || [])
                .sort((a, b) => a.totalCount - b.totalCount)
                .map(m => m.name);

            return owners.length 
                ? `<div class="single-flower-block flower-found fade-in-box">🌸 <strong>${name}</strong> có <strong>${owners.length}</strong> thành viên vớt được (Xếp từ ít hoa nhất 👇):<br>👉 <em>${owners.join(', ')}</em></div>`
                : `<div class="single-flower-block flower-empty fade-in-box">🌸 <strong>${name}</strong>: Cả đảo chưa ai vớt được.</div>`;
        }).join('');
    }

    flowerInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(searchFlowerLogic, 250);
    });

    // ----- DANH SÁCH HOA XU CHƯA NHẶT -----
    function updateMissingXu() {
        const ownedSet = new Set();
        finalMembersData.forEach(m => m.allFlowers.forEach(f => ownedSet.add(f)));
        
        const uniqueMissing = xuList
            .filter(f => !ownedSet.has(f))
            .sort((a, b) => {
                const weightA = getFlowerWeight(a).score;
                const weightB = getFlowerWeight(b).score;
                return weightB - weightA || a.localeCompare(b, 'vi');
            });

        if (uniqueMissing.length === 0) {
            missingArea.innerHTML = `<div class="all-cleared-msg fade-in-box">🎉 Đã vớt hết hoa xu đến hiện tại, mọi người cần thì trade hoa với nhau nhé ^^ 🌸</div>`;
        } else {
            missingArea.innerHTML = uniqueMissing.map(item => {
                const { className } = getFlowerWeight(item);
                return `<span class="flower-chip-item ${className}">${item}</span>`;
            }).join('');
        }
    }

    // ----- CHUYỂN TAB THÔNG TIN -----
    const toggleBox = (showBox, hideBox1, hideBox2) => {
        const isShowing = showBox.style.display === "block";
        [showBox, hideBox1, hideBox2].forEach(box => {
            box.style.display = "none";
            box.classList.remove("fade-in-box");
        });
        if (!isShowing) {
            showBox.style.display = "block";
            showBox.classList.add("fade-in-box");
        }
    };

    document.getElementById('btnHelp').addEventListener('click', () => toggleBox(helpBox, rankBox, missingBox));
    document.getElementById('btnRank').addEventListener('click', () => toggleBox(rankBox, helpBox, missingBox));
    document.getElementById('btnXu').addEventListener('click', () => toggleBox(missingBox, helpBox, rankBox));

    // Khởi chạy việc lấy dữ liệu từ Google Sheet khi load trang
    loadDataFromSheet();
</script>
