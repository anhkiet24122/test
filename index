        { name: "Mộng Linh (Muộn)", flowers: ["Gấu bông", "Bụp hồng cận hồng", "Dạ yến thảo lam", "Hoa anh thảo hồng", "Nhài nhật", "Diên vĩ đức trắng vàng", "Cây sống đời vàng", "Cây holly vòng xanh", "Trái tim đá quý", "Hải đường đỏ", "Hoa poppy himalaya xanh"] },
        { name: "Zishang(Naaa)", flowers: ["Dạ yến thảo lam", "Hoa anh thảo hồng", "Hoa anh thảo xanh", "Lạp mai đỏ", "Hồng champagne", "Hoa hải quỳ trắng", "Hoa hành tím", "Vạn tuế lá lam", "Hoa poppy himalaya xanh", "Hải quỳ đỏ", "Thược dược đỏ", "Thược dược trắng", "Cây holly vòng xanh", "Bụp hồng cận hồng"] }
    ];

    // --- 2. HỆ THỐNG TRA CỨU TỐI ƯU ---
    const cleanFormat = str => str ? str.trim().toLowerCase() : '';

    const displayNameMap = new Map();
    const flowerOwnersMap = new Map();
    const flowerTierMap = new Map();

    // Đồng bộ lại toàn bộ dữ liệu viết Hoa/Thường sang CleanKey
    rawPinkList.forEach(f => flowerTierMap.set(cleanFormat(f), 4));
    rawOrangeList.forEach(f => flowerTierMap.set(cleanFormat(f), 3));
    rawPurpleList.forEach(f => flowerTierMap.set(cleanFormat(f), 2));
    rawGreenList.forEach(f => flowerTierMap.set(cleanFormat(f), 1));

    // Khởi tạo trước kho dữ liệu hoa hiển thị chuẩn xác
    [...rawXuList, ...rawPinkList, ...rawOrangeList, ...rawPurpleList, ...rawGreenList].forEach(f => {
        const cf = cleanFormat(f);
        if (!displayNameMap.has(cf)) {
            displayNameMap.set(cf, f);
            flowerOwnersMap.set(cf, []);
        }
    });

    function getFlowerWeight(cf) {
        const score = flowerTierMap.has(cf) ? flowerTierMap.get(cf) : 2; 
        const tierClasses = { 1: 'tier-green', 2: 'tier-purple', 3: 'tier-orange', 4: 'tier-pink' };
        return { score, className: tierClasses[score] };
    }

    const membersData = rawMembers.map(m => {
        const uniqueCleanFlowers = [...new Set(m.flowers.map(f => {
            const cf = cleanFormat(f);
            if (!displayNameMap.has(cf)) {
                displayNameMap.set(cf, f); 
                flowerOwnersMap.set(cf, []);
            }
            return cf;
        }))];

        const totalCount = uniqueCleanFlowers.filter(cf => getFlowerWeight(cf).score >= 2).length;
        const memberObj = { name: m.name, allFlowers: uniqueCleanFlowers, totalCount };
        
        uniqueCleanFlowers.forEach(cf => flowerOwnersMap.get(cf).push(memberObj));
        return memberObj;
    });

    // --- 3. CÁC HÀM XỬ LÝ CHỨC NĂNG ---
    const mainRankArea = document.getElementById('mainRankArea');
    const searchResultArea = document.getElementById('searchResultArea');
    const missingArea = document.getElementById('missingArea');
    const missingBox = document.getElementById('missingBox');
    const rankBox = document.getElementById('rankBox');
    const helpBox = document.getElementById('helpBox');
    const flowerInput = document.getElementById('flowerSearch');
    const defaultGardenWidgets = document.getElementById('defaultGardenWidgets');
    const searchViewArea = document.getElementById('searchViewArea');

    function initRenderRankList() {
        mainRankArea.innerHTML = `<div class="total-badge">🌱 Tổng số: ${membersData.length} thành viên</div>`;
        const container = document.createElement('div');
        container.className = "rank-list-container";

        const sortedRank = [...membersData].sort((a, b) => b.totalCount - a.totalCount);
        const rankColors = ["#ffb703", "#fb8500", "#219ebc", "#d6ccc2"];

        sortedRank.forEach((item, index) => {
            const collapseItem = document.createElement('div');
            const isBoy = item.name.includes("Cá chiên") || item.name.includes("ChồgcủaHạDi");
            
            collapseItem.className = isBoy ? "cute-rank-item gentleman-card-style" : "cute-rank-item";

            const sortedFlowersWithTier = item.allFlowers.map(f => ({ name: f, ...getFlowerWeight(f) }))
                .sort((a, b) => b.score - a.score || displayNameMap.get(a.name).localeCompare(displayNameMap.get(b.name), 'vi'));

            let tierCounts = { 4: 0, 3: 0, 2: 0, 1: 0 };
            
            const chipsHtml = sortedFlowersWithTier.map(f => {
                tierCounts[f.score]++;
                return `<span class="flower-chip-item ${f.className}">${displayNameMap.get(f.name)}</span>`;
            }).join('');
            
            const summaryHtml = `<div class="summary-rarity-line">👑 <strong>Đội hình tính điểm (Tím trở lên):</strong> ${tierCounts[4]} Hồng | ${tierCounts[3]} Cam | ${tierCounts[2]} Tím</div>`;
            const numColor = index < 3 ? rankColors[index] : rankColors[3];

            collapseItem.innerHTML = `
                <div class="click-header-line">
                    <div class="header-left">
                        <span class="rank-number" style="color: ${numColor};">#${index + 1}</span>
                        <span>${isBoy ? '🎩' : '👑'} ${item.name}</span>
                    </div>
                    <span class="count-badge">${item.totalCount} loại hoa</span>
                </div>
                <div class="rank-content-box">
                    ${summaryHtml}
                    <div class="flower-chip-container">${chipsHtml}</div>
                </div>
            `;

            collapseItem.querySelector('.click-header-line').addEventListener('click', () => collapseItem.classList.toggle('active-folder'));
            container.appendChild(collapseItem);
        });
        mainRankArea.appendChild(container);
    }

    function searchFlowerLogic() {
        const fKey = cleanFormat(flowerInput.value);
        if (fKey === "") {
            searchViewArea.style.display = "none";
            defaultGardenWidgets.style.display = "flex";
            return;
        }

        defaultGardenWidgets.style.display = "none";
        searchViewArea.style.display = "block";
        
        const sortedMatches = Array.from(displayNameMap.keys())
            .filter(clean => clean.includes(fKey))
            .sort((a, b) => displayNameMap.get(a).localeCompare(displayNameMap.get(b), 'vi'));

        if (!sortedMatches.length) {
            searchResultArea.innerHTML = `<div class="single-flower-block flower-not-found">❌ Không tìm thấy loại hoa nào chứa từ khóa "${flowerInput.value}"</div>`;
            return;
        }

        searchResultArea.innerHTML = sortedMatches.map(cf => {
            const owners = (flowerOwnersMap.get(cf) || [])
                .sort((a, b) => a.totalCount - b.totalCount)
                .map(m => m.name);

            const displayTitle = displayNameMap.get(cf);

            return owners.length 
                ? `<div class="single-flower-block flower-found">🌸 <strong>${displayTitle}</strong> hiện có <strong>${owners.length}</strong> thành viên sở hữu (Xếp từ ít hoa nhất 👇):<br>👉 <em>${owners.join(', ')}</em></div>`
                : `<div class="single-flower-block flower-empty">🌸 <strong>${displayTitle}</strong>: Hiện chưa có thành viên nào sở hữu.</div>`;
        }).join('');
    }

    function updateMissingXu() {
        const ownedCleanSet = new Set();
        membersData.forEach(m => m.allFlowers.forEach(cf => ownedCleanSet.add(cf)));
        
        const uniqueMissing = rawXuList.filter(item => !ownedCleanSet.has(cleanFormat(item)))
                                       .sort((a, b) => a.localeCompare(b, 'vi'));
                                       
        missingArea.innerHTML = uniqueMissing.map(item => `<span class="xu-missing-badge">${item}</span>`).join('');
    }

    const toggleBox = (showBox, hideBox1, hideBox2) => {
        if (showBox.style.display === "block") {
            showBox.style.display = "none";
        } else {
            showBox.style.display = "block";
            hideBox1.style.display = "none";
            hideBox2.style.display = "none";
        }
    };

    document.getElementById('btnHelp').addEventListener('click', () => toggleBox(helpBox, rankBox, missingBox));
    document.getElementById('btnRank').addEventListener('click', () => toggleBox(rankBox, helpBox, missingBox));
    document.getElementById('btnXu').addEventListener('click', () => toggleBox(missingBox, helpBox, rankBox));

    initRenderRankList();
    flowerInput.addEventListener('input', searchFlowerLogic);
    updateMissingXu();
</script>
